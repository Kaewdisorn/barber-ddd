generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["barber"]
}

model Customer {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  phone        String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@schema("barber")
}